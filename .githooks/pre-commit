#!/bin/bash

KEYS=("김범진" "beomjinkim2000" "박창준" "cjkj1234" "유재열" "YuY9897" "YuJY9897" "황원재" "zipdid")
VALS=("김범진(PM)" "김범진(PM)" "박창준(Exp)" "박창준(Exp)" "유재열(Model)" "유재열(Model)" "유재열(Model)" "황원재(Data)" "황원재(Data)")

GIT_USER=$(git config user.name | python3 -c "import sys,unicodedata; sys.stdout.write(unicodedata.normalize('NFC',sys.stdin.read().strip()))")
AUTHOR="$GIT_USER"

for i in "${!KEYS[@]}"; do
  if [ "${KEYS[$i]}" = "$GIT_USER" ]; then
    AUTHOR="${VALS[$i]}"
    break
  fi
done

while IFS= read -r FILE; do
  [ -f "$FILE" ] || continue

  # 경로도 NFC 정규화 후 판별
  FILE_NFC=$(echo "$FILE" | python3 -c "import sys,unicodedata; sys.stdout.write(unicodedata.normalize('NFC',sys.stdin.read().strip()))")

  if echo "$FILE_NFC" | grep -q "전체 공지사항/"; then
    SIGN_BODY=0
  else
    SIGN_BODY=1
  fi

  TMPFILE=$(mktemp)
  awk -v author=" - $AUTHOR" -v sign_body="$SIGN_BODY" '
    BEGIN {
      in_body=0; in_comments=0
      last_body=0; last_comment=0
    }
    /white-space:nowrap">내용</ { in_body=1; in_comments=0; lines[NR]=$0; next }
    /white-space:nowrap">본문</ { in_body=1; in_comments=0; lines[NR]=$0; next }
    /white-space:nowrap">댓글</ { in_body=0; in_comments=1; lines[NR]=$0; next }
    /^---$/ { lines[NR]=$0; next }
    {
      lines[NR]=$0
      if(in_body && $0!="")    last_body=NR
      if(in_comments && $0!="") last_comment=NR
    }
    END {
      for(i=1; i<=NR; i++) {
        print lines[i]
        if(sign_body && last_body>0 && i==last_body && lines[last_body]!=author) {
          print author
        }
        if(last_comment>0 && i==last_comment && lines[last_comment]!=author) {
          print author
          print ""
        }
      }
    }
  ' "$FILE" > "$TMPFILE"

  if ! diff -q "$FILE" "$TMPFILE" > /dev/null 2>&1; then
    mv "$TMPFILE" "$FILE"
    git add "$FILE"
  else
    rm "$TMPFILE"
  fi
done < <(git diff --cached --name-only --diff-filter=AM | python3 -c "
import sys, unicodedata, re
for line in sys.stdin:
    line = unicodedata.normalize('NFC', line.strip())
    if re.search(r'(자유게시판|전체 공지사항)/.*\.md$', line):
        print(line)
")

exit 0
