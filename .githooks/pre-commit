for line in sys.stdin:
    line = unicodedata.normalize('NFC', line.strip())
    if re.search(r'게시판/\[Q&A\].*\.md$', line):
        print(line)
" | while IFS= read -r QNA_FILE; do
  TITLE=$(basename "$QNA_FILE" .md | sed 's/^\[Q&A\]-//')

  HEAD_HAS_ANSWER=$(git show "HEAD:$QNA_FILE" 2>/dev/null | python3 -c '
import sys
in_a=False
for line in sys.stdin:
    if "white-space:nowrap\">답변<" in line:
        in_a=True; continue
