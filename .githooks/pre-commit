#!/bin/bash

KEYS=("김범진" "beomjinkim2000" "박창준" "cjkj1234" "유재열" "YuY9897" "YuJY9897" "황원재" "zipdid")
VALS=("김범진(PM)" "김범진(PM)" "박창준(Exp)" "박창준(Exp)" "유재열(Model)" "유재열(Model)" "유재열(Model)" "황원재(Data)" "황원재(Data)")

GIT_USER=$(git config user.name | python3 -c "import sys,unicodedata; sys.stdout.write(unicodedata.normalize('NFC',sys.stdin.read().strip()))")
AUTHOR="$GIT_USER"

for i in "${!KEYS[@]}"; do
  if [ "${KEYS[$i]}" = "$GIT_USER" ]; then
    AUTHOR="${VALS[$i]}"
    break
  fi
done

while IFS= read -r FILE; do
  [ -f "$FILE" ] || continue

  FILE_NFC=$(echo "$FILE" | python3 -c "import sys,unicodedata; sys.stdout.write(unicodedata.normalize('NFC',sys.stdin.read().strip()))")

  # 공지사항 또는 Q&A는 본문/질문 서명 안 함
  if echo "$FILE_NFC" | grep -q "전체 공지사항/" || echo "$FILE_NFC" | grep -qF "[Q&A]"; then
    SIGN_BODY=0
  else
    SIGN_BODY=1
  fi

  TMPFILE=$(mktemp)
  awk -v author=" - $AUTHOR" -v sign_body="$SIGN_BODY" '
    BEGIN {
      in_body=0; in_answer=0; in_comments=0
      last_body=0; last_answer=0; last_comment=0
    }
    /white-space:nowrap">질문</  { in_body=1; in_answer=0; in_comments=0; lines[NR]=$0; next }
    /white-space:nowrap">본문</  { in_body=1; in_answer=0; in_comments=0; lines[NR]=$0; next }
    /white-space:nowrap">내용</  { in_body=1; in_answer=0; in_comments=0; lines[NR]=$0; next }
    /white-space:nowrap">답변</  { in_body=0; in_answer=1; in_comments=0; lines[NR]=$0; next }
    /white-space:nowrap">댓글</  { in_body=0; in_answer=0; in_comments=1; lines[NR]=$0; next }
    /^---$/ { lines[NR]=$0; next }
    {
      lines[NR]=$0
      if(in_body    && $0!="") last_body=NR
      if(in_answer  && $0!="") last_answer=NR
      if(in_comments && $0!="") last_comment=NR
    }
    END {
      for(i=1; i<=NR; i++) {
        print lines[i]
        if(sign_body && last_body>0 && i==last_body && lines[last_body]!=author) {
          print author
        }
        if(last_answer>0 && i==last_answer && lines[last_answer]!=author) {
          print author
          print ""
        }
        if(last_comment>0 && i==last_comment && lines[last_comment]!=author) {
          print author
          print ""
        }
      }
    }
  ' "$FILE" > "$TMPFILE"

  if ! diff -q "$FILE" "$TMPFILE" > /dev/null 2>&1; then
    mv "$TMPFILE" "$FILE"
    git add "$FILE"
  else
    rm "$TMPFILE"
  fi
done < <(git diff --cached --name-only --diff-filter=AM | python3 -c "
import sys, unicodedata, re
for line in sys.stdin:
    line = unicodedata.normalize('NFC', line.strip())
    if re.search(r'(게시판|전체 공지사항)/.*\.md$', line):
        print(line)
")

# 새 Q&A 파일 커밋 시 Discord 알림
DISCORD_WEBHOOK="https://discord.com/api/webhooks/1493432111548465244/33ebLhZEHh6FX3PRJBcP8T1MvkuxUoSTJtzruBTpSBeWYc8LCgXfTmHtznAuqmsarrOv"
DBG="/tmp/pre-commit-debug.log"
echo "=== $(date) ===" >> "$DBG"

git -c core.quotepath=false diff --cached --name-only --diff-filter=AM | python3 -c "
import sys, unicodedata, re
for line in sys.stdin:
    line = unicodedata.normalize('NFC', line.strip())
    sys.stderr.write('CANDIDATE: ' + repr(line) + '\n')
    if re.search(r'게시판/\[Q&A\].*\.md$', line):
        print(line)
" 2>> "$DBG" | while IFS= read -r QNA_FILE; do
  echo "MATCHED: $QNA_FILE" >> "$DBG"
  TITLE=$(basename "$QNA_FILE" .md | sed 's/^\[Q&A\]-//')

  HEAD_HAS_QUESTION=$(git show "HEAD:$QNA_FILE" 2>/dev/null | python3 -c '
import sys
in_q=False
for line in sys.stdin:
    if "white-space:nowrap\">질문<" in line:
        in_q=True; continue
    if in_q and "white-space:nowrap\">" in line: break
    if in_q and line.strip() and not line.rstrip().startswith(" - "):
        print("yes"); exit()
print("no")
')
  echo "HEAD_Q: $HEAD_HAS_QUESTION" >> "$DBG"

  echo "--- STAGED CONTENT (first 30 lines) ---" >> "$DBG"
  git show ":$QNA_FILE" 2>> "$DBG" | head -30 >> "$DBG"
  echo "--- END ---" >> "$DBG"

  STAGED_HAS_QUESTION=$(cat "$QNA_FILE" | python3 -c '
import sys
in_q=False
for line in sys.stdin:
    if "white-space:nowrap\">질문<" in line:
        in_q=True; continue
    if in_q and "white-space:nowrap\">" in line: break
    if in_q and line.strip() and not line.rstrip().startswith(" - "):
        print("yes"); exit()
print("no")
')
  echo "STAGED_Q: $STAGED_HAS_QUESTION" >> "$DBG"

  if [ "$HEAD_HAS_QUESTION" = "no" ] && [ "$STAGED_HAS_QUESTION" = "yes" ]; then
    echo "SENDING..." >> "$DBG"
    /usr/bin/curl -s -w "%{http_code}" -o /dev/null -X POST "$DISCORD_WEBHOOK" \
      -H "Content-Type: application/json" \
      -d "{\"content\": \"❓ **새 질문이 등록됐어요!** 아는 분 답변 부탁드립니다 🙏\n> **제목:** ${TITLE}\"}" >> "$DBG"
  fi
done

# 답변 첫 등록 시 Discord 알림
git -c core.quotepath=false diff --cached --name-only --diff-filter=M | python3 -c "
import sys, unicodedata, re
for line in sys.stdin:
    line = unicodedata.normalize('NFC', line.strip())
    if re.search(r'게시판/\[Q&A\].*\.md$', line):
        print(line)
" | while IFS= read -r QNA_FILE; do
  TITLE=$(basename "$QNA_FILE" .md | sed 's/^\[Q&A\]-//')

  HEAD_HAS_ANSWER=$(git show "HEAD:$QNA_FILE" 2>/dev/null | python3 -c '
import sys
in_a=False
for line in sys.stdin:
    if "white-space:nowrap\">답변<" in line:
        in_a=True; continue
    if in_a and "white-space:nowrap\">" in line: break
    if in_a and line.strip() and not line.rstrip().startswith(" - "):
        print("yes"); exit()
print("no")
')

  STAGED_HAS_ANSWER=$(git show ":$QNA_FILE" 2>/dev/null | python3 -c '
import sys
in_a=False
for line in sys.stdin:
    if "white-space:nowrap\">답변<" in line:
        in_a=True; continue
    if in_a and "white-space:nowrap\">" in line: break
    if in_a and line.strip() and not line.rstrip().startswith(" - "):
        print("yes"); exit()
print("no")
')

  if [ "$HEAD_HAS_ANSWER" = "no" ] && [ "$STAGED_HAS_ANSWER" = "yes" ]; then
    /usr/bin/curl -s -o /dev/null -X POST "$DISCORD_WEBHOOK" \
      -H "Content-Type: application/json" \
      -d "{\"content\": \"✅ **답변이 등록됐습니다. 해결됐는지 확인해주세요!**\n> **제목:** ${TITLE}\"}"
  fi
done

exit 0
