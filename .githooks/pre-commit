#!/bin/bash

KEYS=("beomjinkim2000" "cjkj1234" "YuY9897" "zipdid")
VALS=("김범진(PM)" "박창준(Exp)" "유재열(Model)" "황원재(Data)")

GIT_USER=$(git config user.name)
AUTHOR="$GIT_USER"

for i in "${!KEYS[@]}"; do
  if [ "${KEYS[$i]}" = "$GIT_USER" ]; then
    AUTHOR="${VALS[$i]}"
    break
  fi
done

while IFS= read -r FILE; do
  [ -f "$FILE" ] || continue

  # 이미 서명 있으면 스킵
  if grep -q "^ - $AUTHOR" "$FILE"; then
    continue
  fi

  # 마지막 --- 앞에 서명 삽입 (댓글 섹션 안으로)
  TMPFILE=$(mktemp)
  awk -v author="$AUTHOR" '
    /^---$/ { last_sep = NR; last_pos = FNR }
    { lines[NR] = $0 }
    END {
      for (i = 1; i <= NR; i++) {
        if (i == last_sep) {
          print " - " author
          print ""
        }
        print lines[i]
      }
    }
  ' "$FILE" > "$TMPFILE"
  mv "$TMPFILE" "$FILE"
  git add "$FILE"
done < <(git diff --cached --name-only --diff-filter=AM | grep "자유게시판/.*\.md$")

exit 0
