#!/bin/bash

KEYS=("김범진" "beomjinkim2000" "박창준" "cjkj1234" "유재열" "YuY9897" "YuJY9897" "황원재" "zipdid")
VALS=("김범진(PM)" "김범진(PM)" "박창준(Exp)" "박창준(Exp)" "유재열(Model)" "유재열(Model)" "유재열(Model)" "황원재(Data)" "황원재(Data)")

GIT_USER=$(git config user.name | python3 -c "import sys,unicodedata; sys.stdout.write(unicodedata.normalize('NFC',sys.stdin.read().strip()))")
AUTHOR="$GIT_USER"

for i in "${!KEYS[@]}"; do
  if [ "${KEYS[$i]}" = "$GIT_USER" ]; then
    AUTHOR="${VALS[$i]}"
    break
  fi
done

while IFS= read -r FILE; do
  [ -f "$FILE" ] || continue

  # 공지사항은 댓글만 서명
  if echo "$FILE" | grep -q "전체 공지사항/"; then
    SIGN_BODY=0
  else
    SIGN_BODY=1
  fi

  TMPFILE=$(mktemp)
  awk -v author=" - $AUTHOR" -v sign_body="$SIGN_BODY" '
    BEGIN {
      in_body=0; in_comments=0
      last_body=0; last_comment=0
      found_body_sig=0; found_comment_sig=0
    }
    /white-space:nowrap">내용</ { in_body=1; in_comments=0; lines[NR]=$0; next }
    /white-space:nowrap">본문</ { in_body=1; in_comments=0; lines[NR]=$0; next }
    /white-space:nowrap">댓글</ { in_body=0; in_comments=1; lines[NR]=$0; next }
    /^---$/ { lines[NR]=$0; next }
    {
      lines[NR]=$0
      if(in_body && $0!="") {
        last_body=NR
        if($0==author) found_body_sig=1
      }
      if(in_comments && $0!="") {
        last_comment=NR
        if($0==author) found_comment_sig=1
      }
    }
    END {
      for(i=1; i<=NR; i++) {
        print lines[i]
        if(sign_body && !found_body_sig && last_body>0 && i==last_body) print author
        if(!found_comment_sig && last_comment>0 && i==last_comment) print author
      }
    }
  ' "$FILE" > "$TMPFILE"

  if ! diff -q "$FILE" "$TMPFILE" > /dev/null 2>&1; then
    mv "$TMPFILE" "$FILE"
    git add "$FILE"
  else
    rm "$TMPFILE"
  fi
done < <(git diff --cached --name-only --diff-filter=AM | grep -E "(자유게시판|전체 공지사항)/.*\.md$")

exit 0
